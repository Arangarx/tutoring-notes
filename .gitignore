# Defensive: legacy props-flyout debug screenshots must never be committed
docs/handoff/assets/wb-props-flyout-open-*.png

# Playwright integration tutor auth (cookies) — generated locally / CI by auth.setup.ts
tests/integration/.auth/

.vercel
.env*.local
*.tsbuildinfo

# Copied at install time by scripts/copy-pdfjs-worker.mjs.
# The worker file is large (~1MB) and version-locked to the pdfjs-dist
# entry in package-lock.json — re-deriving it from node_modules keeps
# the repo lean and avoids version drift.
public/pdfjs/
public/jsxgraph/

# Scratch file used to pass multi-line commit messages on PowerShell
# (which doesn't accept bash heredocs in `git commit -m`).
.git-commit-msg.tmp

# Local tee logs from the whiteboard regression-net gate (npm run test:wb-sync).
wb-sync*.log

# Generated long-form test audio (scripts/make-test-audio.cjs, make-test-session.cjs).
# Large binaries used for upload/transcribe smokes — never commit.
test-audio*.m4a
test-audio*.mp3
test-session*.m4a
test-session*.mp3

# SEC-1 seed SQL — contains real admin emails; run manually, never commit.
scripts/seed-admin-google.sql
