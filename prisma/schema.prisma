generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PostgreSQL everywhere (local Docker, Neon dev branch, or Neon production).
  // Set DATABASE_URL + DIRECT_URL in .env (gitignored) — see .env.example and docs/LOCAL-DEV.md.
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum NoteStatus {
  DRAFT
  READY
  SENT
}

enum FeedbackKind {
  BUG
  FEEDBACK
}

model Student {
  id          String       @id @default(uuid())
  name        String
  parentEmail String?      // Saved so tutor doesn't re-enter every time
  createdAt   DateTime     @default(now())
  /** Tutor who owns this student (multi-tenant). Null = legacy rows before scoping or env-only admin. */
  adminUserId String?
  adminUser   AdminUser?   @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  /**
   * Per-student default for the whiteboard "Start recording" toggle
   * (Sarah, Apr 2026 pilot ask): some students decline recording, so
   * the workspace should remember that and show Start unticked for
   * them next time. The tutor can still flip it per session — this is
   * just the initial state. Defaults to true so the existing behavior
   * is unchanged for current students until a tutor explicitly opts
   * one out.
   */
  recordingDefaultEnabled Boolean @default(true)
  notes       SessionNote[]
  shareLinks  ShareLink[]
  recordings  SessionRecording[]
  whiteboardSessions WhiteboardSession[]

  @@index([adminUserId])
}

model SessionNote {
  id        String    @id @default(uuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /**
   * Calendar day of the session (no time, no timezone). Stored as Postgres
   * `DATE` so what the tutor types in `<input type="date">` round-trips
   * losslessly regardless of viewer timezone. Display sites MUST format with
   * UTC accessors (`formatDateOnlyDisplay`) — Prisma still hands back a JS
   * `Date` at UTC midnight, which `toLocaleDateString()` would shift west.
   */
  date      DateTime  @db.Date
  topics    String
  homework  String
  /**
   * Where the student stands on what was covered (B4, Sarah pilot
   * feedback). Renamed for parents to "Assessment" in the UI; field
   * stays untouched in the DB so existing rows backfill to "" by default.
   */
  assessment String   @default("")
  /**
   * The DB column stays `nextSteps` for backwards compatibility, but the
   * UI labels it "Plan" everywhere (B4). See `src/lib/ai.ts` — the AI
   * prompt now returns this as `plan` and the server action maps it back
   * to `nextSteps` at the DB boundary.
   */
  nextSteps String
  linksJson String    @default("[]")
  template  String?
  status    NoteStatus @default(DRAFT)
  sentAt    DateTime?

  /** Optional session start/end times. Auto-filled from recording timestamps when available; editable by the tutor. */
  startTime DateTime?
  endTime   DateTime?

  aiGenerated     Boolean  @default(false)
  aiPromptVersion String?

  /** Whether to include the session recordings in the parent share link. Default off. */
  shareRecordingInEmail Boolean @default(false)

  /** Recordings for this note (0 = no recording, 1 = single, N = multi-segment). */
  recordings SessionRecording[]
  /** Whiteboard sessions attached to this note (0..N — same note can collect multiple sessions over time). */
  whiteboardSessions WhiteboardSession[]
  views      NoteView[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([studentId, date])
}

model SessionRecording {
  id          String    @id @default(uuid())
  /** Tutor who owns this recording (multi-tenant). */
  adminUserId String
  adminUser   AdminUser @relation("AdminRecordings", fields: [adminUserId], references: [id], onDelete: Cascade)
  /** Student the session was for. */
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /** Note this recording belongs to. Null until the note is saved. */
  noteId     String?
  note       SessionNote? @relation(fields: [noteId], references: [id], onDelete: SetNull)
  /** Order within the note (0-indexed). Determines Part 1 of N labeling. */
  orderIndex Int          @default(0)

  /**
   * Whiteboard session that produced this recording, if any. The audio
   * was captured by `useWhiteboardRecorder` (which composes the audio
   * recorder under the hood) and the strokes for the same time window
   * live on the WhiteboardSession row's eventsBlobUrl. SetNull so
   * deleting a whiteboard session leaves the audio recoverable for
   * attach-to-note flows.
   */
  whiteboardSessionId String?
  whiteboardSession   WhiteboardSession? @relation("WhiteboardAudio", fields: [whiteboardSessionId], references: [id], onDelete: SetNull)

  /** Private Vercel Blob URL. Never expose directly — generate signed read URLs at render time. */
  blobUrl         String
  mimeType        String
  sizeBytes       Int
  durationSeconds Int?
  transcript      String?

  createdAt DateTime @default(now())

  @@index([adminUserId])
  @@index([studentId])
  @@index([noteId])
  @@index([whiteboardSessionId])
}

/**
 * A live whiteboard tutoring session — the canvas + strokes + audio +
 * (in Phase 2) text/code documents the tutor and student worked through
 * together. Created when the tutor clicks "Start whiteboard session"
 * after acknowledging the consent checkbox; finalized on Stop.
 *
 * The model is intentionally library-agnostic (see plan guardrail #3):
 * the events blob is OUR canonical diff log shape (see
 * `src/lib/whiteboard/event-log.ts`), not Excalidraw's internal shape,
 * so we can swap canvas libraries later without invalidating recorded
 * sessions.
 */
model WhiteboardSession {
  id          String    @id @default(uuid())
  /** Tutor who created the session (multi-tenant ownership). */
  adminUserId String
  adminUser   AdminUser @relation("AdminWhiteboards", fields: [adminUserId], references: [id], onDelete: Cascade)
  /** Student the session was for. */
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  /** Optional link to a note this session produced. SetNull so a note delete leaves the session itself recoverable. */
  noteId      String?
  note        SessionNote? @relation(fields: [noteId], references: [id], onDelete: SetNull)

  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSeconds Int?

  /**
   * Guardrail #4 — tutor checked the consent box before starting.
   * Server-action enforces this on create, the workspace page
   * re-validates on render. Audit trail.
   */
  consentAcknowledged Boolean @default(false)

  /**
   * Vercel Blob URL for the canonical diff event log (JSON).
   * NOT the raw Excalidraw scene shape. Schema documented inline
   * in `src/lib/whiteboard/event-log.ts`. Stored in Blob (not
   * inline on the row) because event logs grow with session length
   * and we already own the upload route + retention policy for Blob
   * storage.
   */
  eventsBlobUrl String

  /**
   * Schema version of the event log on disk. Bumped only when the
   * canonical format itself changes. The replay player switches on
   * this from day one (`switch (schemaVersion) { case 1: ... }`)
   * so old recordings keep playing after a v2.
   */
  eventsSchemaVersion Int @default(1)

  /**
   * Final canvas as a PNG snapshot for thumbnails + multimodal AI.
   * Optional because exportToBlob can fail on Stop and we never want
   * a snapshot failure to block the events.json upload.
   */
  snapshotBlobUrl String?

  /**
   * Sarah's explicit ask (blocker #24): session timer that starts when
   * BOTH parties first connect to the live room and is read by both
   * clients to compute elapsed. Survives one-side disconnect — the
   * other side's clock keeps running off this fixed point. Null until
   * the student joins (tutor-solo sessions stay null and show no timer).
   *
   * Kept for backwards compatibility + the read-only review surface
   * ("session anchor" in case a tutor wants to know when the student
   * first showed up). NOT used as the displayed timer anymore — see
   * `activeMs` / `lastActiveAt` for the Wyzant-style billable clock.
   */
  bothConnectedAt DateTime?

  /**
   * Wyzant-style billable time: total milliseconds during which BOTH
   * parties were connected to the live room. Persisted by heartbeats
   * from the tutor's workspace via POST /api/whiteboard/[id]/active-ping.
   *
   * Sarah's expectation (Apr 2026): "the timer should pause when the
   * student isn't there". Storing the accumulated value (rather than
   * computing wall-clock from `bothConnectedAt`) means a student drop /
   * tutor refresh / brief network blip never adds time the parties
   * weren't actually together. Survives reload because the server is
   * the source of truth — the workspace re-fetches on mount.
   */
  activeMs Int @default(0)

  /**
   * Server-observed timestamp of the last "still active" heartbeat.
   * Null when the workspace last reported `active=false` (student
   * disconnected, tab closed, tutor refreshed). The next ping with
   * `active=true` adds (now - lastActiveAt) to `activeMs` ONLY if the
   * gap is below the staleness threshold (~30s) — bigger gaps are
   * treated as a fresh segment so a closed tab doesn't bill until the
   * next heartbeat.
   */
  lastActiveAt DateTime?

  /** Audio segments captured alongside the strokes (parallel to SessionNote.recordings). */
  audioRecordings SessionRecording[]    @relation("WhiteboardAudio")
  /** Tokenized join links the tutor mints to invite the student to the live session. */
  joinTokens      WhiteboardJoinToken[]

  createdAt DateTime @default(now())

  @@index([adminUserId])
  @@index([studentId])
  @@index([noteId])
}

/**
 * Tokenized join link the tutor sends to the student so they can enter
 * the live whiteboard room without an account. Same trust pattern as
 * `ShareLink` for parents — the token IS the credential, so it's
 * scoped to the session, time-limited (default 30 min), and revocable
 * on tutor Stop.
 */
model WhiteboardJoinToken {
  id                  String   @id @default(uuid())
  whiteboardSessionId String
  whiteboardSession   WhiteboardSession @relation(fields: [whiteboardSessionId], references: [id], onDelete: Cascade)
  token               String   @unique
  expiresAt           DateTime
  revokedAt           DateTime?
  createdAt           DateTime @default(now())

  @@index([whiteboardSessionId])
  @@index([token])
}

model NoteView {
  id         String   @id @default(uuid())
  /** Share link token (not an FK — survives link regeneration, old views just become orphans). */
  shareToken String
  noteId     String
  note       SessionNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  seenAt     DateTime @default(now())

  @@unique([shareToken, noteId])
  @@index([shareToken])
}

model ShareLink {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  token     String   @unique
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([studentId])
}

model EmailMessage {
  id          String     @id @default(uuid())
  toEmail     String
  subject     String
  bodyText    String
  linkUrl     String
  createdAt   DateTime   @default(now())
  adminUserId String?
  adminUser   AdminUser? @relation("AdminEmailMessages", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model FeedbackItem {
  id           String       @id @default(uuid())
  kind         FeedbackKind
  message      String
  page         String?
  contactEmail String? // optional — so we can reply
  createdAt    DateTime     @default(now())
}

model AdminUser {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  displayName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  students      Student[]
  emailMessages EmailMessage[] @relation("AdminEmailMessages")
  emailConfigs  EmailConfig[] @relation("AdminEmailConfigs")
  oauthConnections OAuthEmailConnection[] @relation("AdminOAuthConnections")
  recordings    SessionRecording[] @relation("AdminRecordings")
  whiteboardSessions WhiteboardSession[] @relation("AdminWhiteboards")
}

// One-time password reset links (hashed token, email delivery).
model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model EmailConfig {
  id          String     @id @default(uuid())
  host        String
  port        Int        @default(587)
  secure      Boolean    @default(false)
  user        String
  password    String
  fromEmail   String?
  updatedAt   DateTime   @updatedAt
  adminUserId String?
  adminUser   AdminUser? @relation("AdminEmailConfigs", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model OAuthEmailConnection {
  id           String     @id @default(uuid())
  provider     String
  refreshToken String
  email        String
  updatedAt    DateTime   @updatedAt
  adminUserId  String?
  adminUser    AdminUser? @relation("AdminOAuthConnections", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

// Waitlist entries from the landing page interest form.
model WaitlistEntry {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  note      String?
  createdAt DateTime @default(now())
}

