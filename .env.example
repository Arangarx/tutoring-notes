# =============================================================================
# Copy this file to `.env` and fill in values. Never commit `.env`.
# =============================================================================
#
# DATABASE_URL / DIRECT_URL
# -------------------------
# Same provider everywhere (PostgreSQL). Switch environments by changing .env
# only — the Prisma schema stays on `postgresql` in git.
#
# Local option A — Docker (see docker-compose.yml):
#   docker compose up -d
#   Use the URLs below (non-pooled; direct = same as url for local Postgres).
#
# Local option B — Neon “dev” branch:
#   Paste pooled → DATABASE_URL, direct → DIRECT_URL from the Neon dashboard.
#
# Production — Neon:
#   DATABASE_URL = pooled connection string (hostname often contains "-pooler")
#   DIRECT_URL   = direct (unpooled) — required for prisma migrate / db push; must NOT be the pooler URL
#                  or advisory locks fail on deploy (see docs/DEPLOY.md).
#
# Even with the pooled URL, serverless can still see transient
# `kind: Closed` connection drops between invocations. The app handles these
# via `withDbRetry()` in `src/lib/db.ts` (auto-retries 2x with backoff) — see
# /docs/learning-prisma.md for the full pattern. If you see a *sustained* burst
# of those errors in logs, check the Neon dashboard for a pooler restart or
# scale-down event.
#
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/tutoring_notes"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/tutoring_notes"

# Jest uses TEST_DATABASE_URL if set; otherwise defaults to docker test DB (see jest.global-setup.ts).
# TEST_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/tutoring_notes_test"

# Public URL of this app — used for password-reset links and OAuth redirects. Must match production URL when deployed.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-a-random-string"

# Optional: use first-run setup at /setup to create an admin in the DB instead.
# If set, you can log in with these until an admin exists in the DB.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-me"

# Production (Vercel): required to use /setup — visit /setup?token=<same value>. ≥16 chars. Omit locally for open /setup.
# SETUP_SECRET=""

# Optional: when set, "Send update" actually sends email via SMTP.
# If unset, messages are stored in the outbox only (no real send).
# For pilots: use Resend (resend.com) SMTP relay — free tier covers early usage.
# Resend SMTP: host=smtp.resend.com port=465 secure=true user=resend pass=<API_KEY>
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"

# Optional: for "Connect Gmail" (OAuth). Deployer sets once; users never touch.
# Create credentials in Google Cloud Console (APIs & Services → Credentials → OAuth 2.0 Client ID).
# Authorized redirect URI: https://your-domain/api/auth/gmail/callback (or http://localhost:3000/... for dev).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional: comma-separated emails allowed to use Connect Gmail. If unset, any signed-in tutor may connect.
# Set this when you allow public /signup but only want OAuth for yourself and trusted pilots (e.g. you@gmail.com,pilot@friend.com).
# GMAIL_CONNECT_ALLOWLIST=""

# Who may open **global** feedback inbox + waitlist (not ordinary tutors). Comma-separated.
# `ADMIN_EMAIL` above is always treated as an operator even if you omit it here.
# If neither yields any address, no one can open those pages until you set this (secure default).
# OPERATOR_EMAILS="you@example.com"

# Optional: AI note generation (Auto-fill from session text panel).
# Create a dedicated key at platform.openai.com/api-keys and set a monthly spend cap ($20/mo recommended).
# If absent, the AI panel shows "not configured" — no errors, no crashes.
# OPENAI_API_KEY=""

# Optional: Vercel Blob storage for session audio recordings.
# Automatically injected by Vercel when you connect a Blob store to the project (Storage tab).
# For local dev: run `npx vercel link` then `npx vercel env pull .env.local`.
# If absent, audio upload/record is hidden — no errors, no crashes.
# BLOB_READ_WRITE_TOKEN=""

# Whiteboard live-collaboration relay (Phase 1 whiteboard).
# Production: wss://wb.mortensenapps.com — deployed from
#   agentic-projects/whiteboard-sync/ (see that README for `fly deploy`).
# Local dev: run `docker run -p 3002:3002 ...` and set ws://localhost:3002.
# When unset, the whiteboard runs in tutor-solo mode (recording works,
# but the student can't join the live session).
# WHITEBOARD_SYNC_URL="wss://wb.mortensenapps.com"

# ---------------------------------------------------------------------------
# Identity Phase 1: TOTP 2FA
# ---------------------------------------------------------------------------
# REQUIRED in production for any deployment with real admins.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# This key encrypts TOTP secrets at rest in the database (AES-256-GCM).
# WARNING: Rotating or losing this key requires re-enrolling ALL tutors —
#   there is no dual-key decrypt in V1. See docs/PLATFORM-ASSUMPTIONS.md.
# TOTP_ENCRYPTION_KEY="<32-byte base64url — see command above>"

# ---------------------------------------------------------------------------
# Identity Phase 2a: AccountHolder + Learner session infrastructure
# ---------------------------------------------------------------------------
# AH_SESSION_HMAC_SECRET — signs AccountHolder session tokens (mynk_ah_session cookie).
# Required in production for AccountHolder auth. Treat at same security tier as NEXTAUTH_SECRET.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# AH_SESSION_HMAC_SECRET=""

# LEARNER_SESSION_HMAC_SECRET — signs LearnerDeviceSession tokens (mynk_learner_session cookie).
# Required in production for learner PIN login.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# LEARNER_SESSION_HMAC_SECRET=""

# AH_TOTP_ENCRYPTION_KEY — AES-256-GCM key for AccountHolder TOTP secret encryption (Phase 6).
# Isolated from TOTP_ENCRYPTION_KEY so rotating tutor 2FA does not affect parent 2FA.
# Reserved now; Phase 6 enrollment will fail if unset when 2FA is enabled.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# AH_TOTP_ENCRYPTION_KEY="<32-byte base64url>"