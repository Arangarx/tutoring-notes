{
  "name": "tutoring-notes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node scripts/copy-pdfjs-worker.mjs && node scripts/migrate-with-retry.mjs && next build",
    "postinstall": "prisma generate && node scripts/copy-pdfjs-worker.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:create-admin": "node scripts/create-admin.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test": "jest",
    "test:regression": "jest --testPathPatterns=regressions",
    "test:e2e": "playwright test",
    "test:integration": "playwright test --project=integration",
    "test:e2e:smoke": "playwright test tests/smoke",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@prisma/client": "^6.16.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "ffmpeg-static": "^5.3.0",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "mathjax-full": "^3.2.1",
    "mathlive": "^0.109.1",
    "next": "^15.5.2",
    "next-auth": "^4.24.11",
    "nodemailer": "^7.0.7",
    "openai": "^6.34.0",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^6.16.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "socket.io-client": "^4.8.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "axe-playwright": "^2.2.2",
    "eslint": "^9.33.0",
    "eslint-config-next": "^15.5.2",
    "fake-indexeddb": "^6.2.5",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.3.0",
    "typescript": "^5.9.2"
  }
}
